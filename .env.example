# cou$in frontend environment
# Copy to `.env` and fill in. `.env` is gitignored.

# Backend API base URL (no trailing slash). All API routes live under `${VITE_API_URL}/api`.
# Production: https://cousin-backend.onrender.com
# Local BE:   http://localhost:3000
VITE_API_URL=https://cousin-backend.onrender.com

# Supabase project (for auth / session management on the FE).
# Project ref is derived from the backend DATABASE_URL: sqyeqvivhvghocevzyqs
VITE_SUPABASE_URL=https://sqyeqvivhvghocevzyqs.supabase.co

# Supabase anon/publishable key — paste from Supabase dashboard > Project Settings > API.
# NOT the JWT secret, NOT the service_role key. The anon key is safe in a browser bundle.
VITE_SUPABASE_ANON_KEY=
